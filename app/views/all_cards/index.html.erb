
<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><%= t("all_cards.title") %></h1>
  <% if user_signed_in? %>
    <div class="d-flex gap-2">
      <%= link_to t("all_cards.import_button"), import_cards_path, class: "btn btn-outline-secondary" %>
      <%= link_to t("all_cards.export_button"), export_cards_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>

<% if @cards.any? %>
  <% bulk = current_user&.admin? %>
  <div data-controller="<%= 'bulk-select' if bulk %>"
       data-bulk-select-url-value="<%= bulk_cards_path %>"
       data-bulk-select-confirm-value="<%= t('cards.confirm_bulk_delete_permanent') %>">
    <% if bulk %>
      <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <div class="form-check m-0">
          <input type="checkbox" class="form-check-input" id="select-all"
                 data-bulk-select-target="all" data-action="bulk-select#toggleAll">
          <label class="form-check-label" for="select-all"><%= t("cards.select_all") %></label>
        </div>
        <button type="button" class="btn btn-outline-danger btn-sm" disabled
                data-bulk-select-target="submit" data-action="bulk-select#destroy">
          <%= t("cards.delete_selected") %> (<span data-bulk-select-target="count">0</span>)
        </button>
      </div>
    <% end %>

    <div id="cards" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
      <%= render partial: "all_cards/card", collection: @cards, as: :card %>
    </div>

    <%= render "all_cards/load_more", has_more: @has_more, next_offset: @next_offset %>
  </div>
<% else %>
  <p class="text-muted">
    <%= t("cards.empty_all") %>
    <% if current_user.nil? || current_user.native_language.nil? || current_user.preferred_language.nil? %>
      <%= t("cards.set_both_html", link: link_to(t("cards.your_profile"), edit_user_registration_path)).html_safe %>
    <% end %>
  </p>
<% end %>
