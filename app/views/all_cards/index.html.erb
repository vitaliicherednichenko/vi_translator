<% content_for :title, t("all_cards.title") %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><%= t("all_cards.title") %></h1>
  <% if user_signed_in? %>
    <div class="d-flex gap-2">
      <%= link_to t("all_cards.import_button"), import_cards_path, class: "btn btn-outline-secondary" %>
      <%= link_to t("all_cards.export_button"), export_cards_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>

<% if @cards.any? %>
  <div id="cards" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @cards.each do |card| %>
      <div class="col">
        <div id="<%= dom_id card %>"
             class="flip-card"
             data-controller="flip"
             data-action="click->flip#toggle keydown->flip#toggleKey"
             role="button" tabindex="0"
             aria-label="<%= t('cards.flip_aria') %>">
          <div class="flip-card-inner">
            <div class="flip-card-front bg-body border">
              <% if card.source_language %>
                <span class="badge bg-secondary mb-2"><%= card.source_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.front_text %></span>
            </div>
            <div class="flip-card-back bg-primary text-white">
              <% if card.target_language %>
                <span class="badge bg-light text-dark mb-2"><%= card.target_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.back_text %></span>
            </div>
          </div>
        </div>
        <div class="text-center mt-2">
          <div class="mb-2">
            <%= link_to card.collection.name, collection_path(card.collection),
                        class: "badge text-bg-light text-decoration-none" %>
          </div>
          <div class="d-flex justify-content-center gap-2">
            <%= link_to t("common.view"), collection_card_path(card.collection, card),
                        class: "btn btn-outline-primary btn-sm" %>
            <% if user_signed_in? %>
              <div class="dropdown">
                <button type="button" class="btn btn-outline-success btn-sm dropdown-toggle"
                        data-bs-toggle="dropdown" aria-expanded="false">
                  <%= t("common.add_to") %>
                </button>
                <ul class="dropdown-menu">
                  <li class="dropdown-header"><%= t("common.add_to_collection") %></li>
                  <% @my_collections.each do |collection| %>
                    <li>
                      <%= button_to collection.name,
                                    add_card_to_collection_path(card),
                                    params: { collection_id: collection.id },
                                    class: "dropdown-item" %>
                    </li>
                  <% end %>
                  <% if @my_collections.empty? %>
                    <li><span class="dropdown-item-text text-muted"><%= t("common.no_collections_yet") %></span></li>
                  <% end %>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to t("nav.new_collection"), new_collection_path, class: "dropdown-item" %></li>
                </ul>
              </div>
            <% end %>
            <% if policy(card).destroy? %>
              <%= button_to t("common.delete"), collection_card_path(card.collection, card), method: :delete,
                            class: "btn btn-outline-danger btn-sm",
                            form: { data: { turbo_confirm: t("common.confirm_delete_card"), turbo_preserve_scroll: true } } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">
    <%= t("cards.empty_all") %>
    <% if current_user.nil? || current_user.native_language.nil? || current_user.preferred_language.nil? %>
      <%= t("cards.set_both_html", link: link_to(t("cards.your_profile"), edit_user_registration_path)).html_safe %>
    <% end %>
  </p>
<% end %>
