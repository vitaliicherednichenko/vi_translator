<nav class="navbar navbar-expand-lg navbar-dark bg-navy mb-4">
  <div class="container">
    <%= link_to t("app_name"), root_path, class: "navbar-brand" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to t("nav.collections"), collections_path, class: "nav-link #{'active' if controller_name == 'collections'}" %>
        </li>
        <li class="nav-item">
          <%= link_to t("nav.cards"), cards_path, class: "nav-link #{'active' if controller_name == 'all_cards' || controller_name == 'cards'}" %>
        </li>
        <% if controller_name == "all_cards" || controller_name == "cards" %>
          <li class="nav-item">
            <button type="button" class="nav-link border-0 bg-transparent"
                    data-controller="reverse-cards"
                    data-reverse-cards-back-label-value="<%= t('nav.back_side') %>"
                    data-reverse-cards-front-label-value="<%= t('nav.front_side') %>"
                    data-action="reverse-cards#toggle"
                    title="<%= t('nav.back_side_title') %>">
              <%= t("nav.back_side") %>
            </button>
          </li>
        <% end %>

        <% if user_signed_in? %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle <%= 'active' if controller_name == 'cards' %>" href="#"
               role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= t("nav.my_cards") %>
            </a>
            <ul class="dropdown-menu">
              <li class="dropdown-header"><%= t("nav.my_collections") %></li>
              <% my_collections = current_user.collections.in_user_languages(current_user).order(:name).limit(6).to_a %>
              <% my_collections.first(5).each do |collection| %>
                <li>
                  <%= link_to collection.name, collection_cards_path(collection), class: "dropdown-item" %>
                </li>
              <% end %>
              <% if my_collections.empty? %>
                <li><span class="dropdown-item-text text-muted"><%= t("nav.no_native_collections") %></span></li>
              <% end %>
              <% if my_collections.size > 5 %>
                <li>
                  <%= link_to "…", collections_path(mine: true),
                              class: "dropdown-item text-center fs-5 lh-1 py-1",
                              title: t("nav.see_all_collections") %>
                </li>
              <% end %>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to t("nav.new_collection"), new_collection_path, class: "dropdown-item" %></li>
              <li><%= link_to t("nav.import_cards"), import_cards_path, class: "dropdown-item" %></li>
              <li><%= link_to t("nav.export_cards"), export_cards_path, class: "dropdown-item" %></li>

              <% deleted_cards = current_user.cards.deleted.includes(:collection).order(deleted_at: :desc).limit(6).to_a %>
              <% if deleted_cards.any? %>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to t("nav.deleted_cards"), deleted_cards_path, class: "dropdown-item dropdown-header fw-semibold text-uppercase" %></li>
                <% deleted_cards.first(5).each do |card| %>
                  <li>
                    <div class="d-flex align-items-center justify-content-between gap-2 px-3 py-1">
                      <%= link_to collection_card_path(card.collection, card), class: "text-reset text-decoration-none small text-truncate" do %>
                        <span class="text-decoration-line-through"><%= card.front_text %></span>
                        <span class="text-muted">· <%= card.collection.name %></span>
                      <% end %>
                      <%= button_to t("common.restore"), restore_collection_card_path(card.collection, card),
                                    method: :patch, class: "btn btn-sm btn-outline-success py-0 px-2" %>
                    </div>
                  </li>
                <% end %>
                <% if deleted_cards.size > 5 %>
                  <li>
                    <%= link_to "…", deleted_cards_path,
                                class: "dropdown-item text-center fs-5 lh-1 py-1",
                                title: t("nav.see_all_deleted") %>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </li>
        <% end %>
        <li class="nav-item">
          <%= link_to t("nav.languages"), languages_path, class: "nav-link #{'active' if controller_name == 'languages'}" %>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            🌐 <%= t("locale_name") %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li class="dropdown-header"><%= t("nav.language_menu") %></li>
            <% I18n.available_locales.each do |loc| %>
              <li>
                <%= link_to url_for(request.query_parameters.merge(locale: loc)),
                            class: "dropdown-item #{'active' if I18n.locale == loc}" do %>
                  <%= t("locale_name", locale: loc) %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </li>

        <% if user_signed_in? %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= current_user.name.presence || current_user.email %>
              <% if current_user.preferred_language %>
                <span class="badge bg-success"><%= current_user.preferred_language.code.upcase %></span>
              <% end %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if current_user.native_language || current_user.preferred_language %>
                <li class="dropdown-header">
                  <% if current_user.native_language %>
                    <%= t("nav.native") %>: <%= current_user.native_language.name %><br>
                  <% end %>
                  <% if current_user.preferred_language %>
                    <%= t("nav.learning") %>: <%= current_user.preferred_language.name %>
                  <% end %>
                </li>
                <li><hr class="dropdown-divider"></li>
              <% end %>
              <li><%= link_to t("nav.edit_profile"), edit_user_registration_path, class: "dropdown-item" %></li>
              <li><%= button_to t("nav.logout"), destroy_user_session_path, method: :delete, class: "dropdown-item" %></li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to t("nav.login"), new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to t("nav.sign_up"), new_user_registration_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
