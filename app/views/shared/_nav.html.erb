<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <%= link_to "Vi Translator", root_path, class: "navbar-brand" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to "Collections", collections_path, class: "nav-link #{'active' if controller_name == 'collections'}" %>
        </li>
        <li class="nav-item">
          <%= link_to "Cards", cards_path, class: "nav-link #{'active' if controller_name == 'all_cards'}" %>
        </li>
        <% if user_signed_in? %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle <%= 'active' if controller_name == 'cards' %>" href="#"
               role="button" data-bs-toggle="dropdown" aria-expanded="false">
              My Cards
            </a>
            <ul class="dropdown-menu">
              <li class="dropdown-header">My Collections</li>
              <% current_user.collections.order(:name).each do |collection| %>
                <li>
                  <%= link_to collection.name, collection_cards_path(collection), class: "dropdown-item" %>
                </li>
              <% end %>
              <% if current_user.collections.empty? %>
                <li><span class="dropdown-item-text text-muted">No collections yet</span></li>
              <% end %>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "New collection", new_collection_path, class: "dropdown-item" %></li>

              <% deleted_cards = current_user.cards.deleted.includes(:collection).order(deleted_at: :desc) %>
              <% if deleted_cards.any? %>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Deleted Cards", deleted_cards_path, class: "dropdown-item dropdown-header fw-semibold text-uppercase" %></li>
                <% deleted_cards.each do |card| %>
                  <li>
                    <div class="d-flex align-items-center justify-content-between gap-2 px-3 py-1">
                      <%= link_to collection_card_path(card.collection, card), class: "text-reset text-decoration-none small text-truncate" do %>
                        <span class="text-decoration-line-through"><%= card.front_text %></span>
                        <span class="text-muted">· <%= card.collection.name %></span>
                      <% end %>
                      <%= button_to "Restore", restore_collection_card_path(card.collection, card),
                                    method: :patch, class: "btn btn-sm btn-outline-success py-0 px-2" %>
                    </div>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </li>
        <% end %>
        <li class="nav-item">
          <%= link_to "Languages", languages_path, class: "nav-link #{'active' if controller_name == 'languages'}" %>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <% if user_signed_in? %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= current_user.name.presence || current_user.email %>
              <% if current_user.preferred_language %>
                <span class="badge bg-success"><%= current_user.preferred_language.code.upcase %></span>
              <% end %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if current_user.native_language || current_user.preferred_language %>
                <li class="dropdown-header">
                  <% if current_user.native_language %>
                    Native: <%= current_user.native_language.name %><br>
                  <% end %>
                  <% if current_user.preferred_language %>
                    Learning: <%= current_user.preferred_language.name %>
                  <% end %>
                </li>
                <li><hr class="dropdown-divider"></li>
              <% end %>
              <li><%= link_to "Edit Profile", edit_user_registration_path, class: "dropdown-item" %></li>
              <li><%= button_to "Logout", destroy_user_session_path, method: :delete, class: "dropdown-item" %></li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign up", new_user_registration_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
