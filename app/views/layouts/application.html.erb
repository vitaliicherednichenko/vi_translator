<!DOCTYPE html>
<html lang="<%= I18n.locale %>" dir="<%= I18n.locale == :ar ? 'rtl' : 'ltr' %>">
  <head>
    <title><%= content_for(:title) || t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Vi Translator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%= render "shared/nav" %>
    <main class="container flex-grow-1">
      <% if flash[:alert] %>
        <div class="alert alert-danger" role="alert"><%= flash[:alert] %></div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="bg-light border-top py-4">
      <div class="container text-center text-muted small">
        Made with <span class="text-danger">❤</span> by
        <%= link_to "Vitalii Cherednichenko", "https://www.linkedin.com/in/vitalii-cherednichenko",
                    target: "_blank", rel: "noopener noreferrer",
                    class: "text-reset fw-semibold" %>
      </div>
    </footer>

    <button type="button"
            class="btn btn-primary rounded-circle shadow scroll-top-btn"
            data-controller="scroll-top"
            data-action="scroll-top#scrollUp"
            title="<%= t('common.back_to_top') %>"
            aria-label="<%= t('common.back_to_top') %>">
      <%= icon("arrow-up") %>
    </button>
  </body>
</html>
