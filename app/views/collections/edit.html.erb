<% content_for :title, "Editing collection" %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <h1 class="mb-4">Editing collection</h1>
    <div class="card shadow-sm">
      <div class="card-body">
        <%= render "form", collection: @collection %>
      </div>
    </div>
    <div class="mt-3 d-flex gap-3">
      <%= link_to "Show this collection", @collection, class: "btn btn-link px-0" %>
      <%= link_to "Back to collections", collections_path, class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
