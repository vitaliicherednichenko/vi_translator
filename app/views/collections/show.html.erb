<% content_for :title, @collection.name %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="mb-0"><%= @collection.name %></h1>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Cards", collection_cards_path(@collection), class: "btn btn-primary" %>
    <%= link_to "Edit", edit_collection_path(@collection), class: "btn btn-outline-secondary" %>
    <%= link_to "Back", collections_path, class: "btn btn-outline-secondary" %>
    <%= button_to "Delete", @collection, method: :delete,
                  class: "btn btn-outline-danger",
                  form: { data: { turbo_confirm: "Are you sure?" } } %>
  </div>
</div>

<%= render @collection %>
