<% heading = @mine ? t("nav.my_collections") : t("collections.title") %>
<% content_for :title, heading %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><%= heading %></h1>
  <% if policy(Collection).create? %>
    <%= link_to t("collections.new_button"), new_collection_path, class: "btn btn-primary" %>
  <% end %>
</div>
<% if current_user %>
  <%= form_with url: collections_path, method: :get, class: "mb-4" do %>
    <%= hidden_field_tag(:mine, "1") if @mine %>
    <div class="input-group">
      <%= search_field_tag :q, @q, class: "form-control", placeholder: t("common.search"), "aria-label": t("common.search") %>
      <%= submit_tag t("common.search"), class: "btn btn-outline-primary" %>
      <% if @q.present? %>
        <%= link_to t("common.clear"), collections_path(mine: (@mine ? "1" : nil)), class: "btn btn-outline-secondary" %>
      <% end %>
    </div>
  <% end %>
<% end %>
<% if @collections.any? %>
  <div id="collections" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @collections.each do |collection| %>
      <div class="col">
        <div id="<%= dom_id collection %>" class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= collection.name %></h5>
            <% if collection.language %>
              <span class="badge bg-success align-self-start mb-2"><%= collection.language.code.upcase %></span>
            <% end %>
            <p class="card-text text-muted small flex-grow-1"><%= collection.description %></p>
            <div class="text-muted small mb-3"><%= t("collections.by", name: collection.user&.name) %></div>
            <div class="d-flex gap-2 mt-auto">
              <%= link_to t("collections.cards_button"), collection_cards_path(collection), class: "btn btn-primary btn-sm" %>
              <%= link_to t("common.view"), collection, class: "btn btn-outline-primary btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% elsif @q.present? %>
  <p class="text-muted"><%= t("common.no_search_results", query: @q) %></p>
<% else %>
  <p class="text-muted">
    <%= t("collections.empty") %>
    <% unless current_user&.native_language || current_user&.preferred_language %>
      <%= t("collections.empty_hint_html", link: link_to(t("collections.your_profile"), edit_user_registration_path)).html_safe %>
    <% end %>
  </p>
<% end %>
