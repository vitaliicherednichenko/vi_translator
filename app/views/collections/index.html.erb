<% content_for :title, "Collections" %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Collections</h1>
  <%= link_to "New collection", new_collection_path, class: "btn btn-primary" %>
</div>

<% if @collections.any? %>
  <div id="collections" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @collections.each do |collection| %>
      <div class="col">
        <div id="<%= dom_id collection %>" class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= collection.name %></h5>
            <% if collection.language %>
              <span class="badge bg-success align-self-start mb-2"><%= collection.language.code.upcase %></span>
            <% end %>
            <p class="card-text text-muted small flex-grow-1"><%= collection.description %></p>
            <div class="text-muted small mb-3">By <%= collection.user&.name %></div>
            <%= link_to "View", collection, class: "btn btn-outline-primary btn-sm mt-auto" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">No collections yet.</p>
<% end %>
