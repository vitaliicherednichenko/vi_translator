<% content_for :title, t("languages.title") %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-4"><%= t("languages.title") %></h1>
  <% if policy(Language).create? %>
    <%= link_to t("languages.new_button"), new_language_path, class: "btn btn-primary" %>
  <% end %>
</div>

<% if @languages.any? %>
  <div id="languages" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @languages.each do |language| %>
      <div class="col">
        <div id="<%= dom_id language %>" class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">
              <%= language.name %>
              <span class="badge bg-secondary"><%= language.code.upcase %></span>
            </h5>
            <p class="card-text text-muted flex-grow-1"><%= language.native_name %></p>
            <%= link_to t("common.view"), language, class: "btn btn-outline-primary btn-sm mt-auto" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted"><%= t("languages.empty") %></p>
<% end %>
