<% content_for :title, "New language" %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <h1 class="mb-4">New language</h1>
    <div class="card shadow-sm">
      <div class="card-body">
        <%= render "form", language: @language %>
      </div>
    </div>
    <div class="mt-3">
      <%= link_to "← Back to languages", languages_path, class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
