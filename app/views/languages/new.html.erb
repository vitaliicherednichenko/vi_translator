<% content_for :title, t("languages.new_title") %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <h1 class="mb-4"><%= t("languages.new_title") %></h1>
    <div class="card shadow-sm">
      <div class="card-body">
        <%= render "form", language: @language %>
      </div>
    </div>
    <div class="mt-3">
      <%= link_to t("languages.back_to_languages"), languages_path, class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
