<div id="<%= dom_id card %>" class="card shadow-sm">
  <div class="card-body">
    <div class="row g-4">
      <div class="col-md-6">
        <h6 class="text-muted text-uppercase small">
          Front<%= " (#{card.source_language.code.upcase})" if card.source_language %>
        </h6>
        <p class="fs-5 mb-0"><%= card.front_text %></p>
      </div>
      <div class="col-md-6">
        <h6 class="text-muted text-uppercase small">
          Back<%= " (#{card.target_language.code.upcase})" if card.target_language %>
        </h6>
        <p class="fs-5 mb-0"><%= card.back_text %></p>
      </div>
    </div>

    <hr>

    <dl class="row mb-0">
      <dt class="col-sm-3">Collection</dt>
      <dd class="col-sm-9"><%= card.collection.name %></dd>

      <dt class="col-sm-3">Owner</dt>
      <dd class="col-sm-9"><%= card.user&.name.presence || tag.span("—", class: "text-muted") %></dd>

      <dt class="col-sm-3">Translation</dt>
      <dd class="col-sm-9"><%= card.translation_pair %></dd>
    </dl>
  </div>
</div>
