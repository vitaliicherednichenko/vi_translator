<% content_for :title, t("cards.card_title") %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="mb-0">
    <%= t("cards.show_heading", name: @collection.name) %>
    <% if @card.deleted? %>
      <span class="badge bg-secondary align-middle"><%= t("cards.deleted_badge") %></span>
    <% end %>
  </h1>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to t("common.back"), collection_cards_path(@collection), class: "btn btn-outline-secondary" %>
    <% if @card.deleted? %>
      <% if policy(@card).restore? %>
        <%= button_to t("common.restore"), restore_collection_card_path(@collection, @card),
                      method: :patch, class: "btn btn-success" %>
      <% end %>
    <% else %>
      <% if policy(@card).update? %>
        <%= link_to t("common.edit"), edit_collection_card_path(@collection, @card), class: "btn btn-outline-secondary" %>
      <% end %>
      <% if policy(@card).destroy? %>
        <%= button_to t("common.delete"), collection_card_path(@collection, @card), method: :delete,
                      class: "btn btn-outline-danger",
                      form: { data: { turbo_confirm: t("common.confirm_generic") } } %>
      <% end %>
    <% end %>
  </div>
</div>

<%= render @card %>
