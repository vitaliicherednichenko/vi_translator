<% content_for :title, "New card" %>

<div class="row justify-content-center">
  <div class="col-lg-10">
    <h1 class="mb-4">New card</h1>
    <div class="card shadow-sm">
      <div class="card-body">
        <%= render "form", card: @card %>
      </div>
    </div>
    <div class="mt-3">
      <%= link_to "← Back to cards", collection_cards_path(@collection), class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
