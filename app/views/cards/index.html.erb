<% content_for :title, t("cards.index_title") %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="mb-0"><%= t("cards.collection_cards", name: @collection.name) %></h1>
  <div class="d-flex flex-wrap gap-2">
    <% if user_signed_in? %>
      <%= link_to t("cards.export_button"), export_collection_cards_path(@collection), class: "btn btn-outline-secondary" %>
    <% end %>
    <% if policy(@collection).update? %>
      <%= link_to t("cards.import_button"), import_collection_cards_path(@collection), class: "btn btn-outline-secondary" %>
    <% end %>
    <% if policy(Card).create? %>
      <%= link_to t("cards.new_button"), new_collection_card_path(@collection), class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<% if @cards.any? %>
  <div id="cards" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @cards.each do |card| %>
      <div class="col">
        <div id="<%= dom_id card %>"
             class="flip-card"
             data-controller="flip"
             data-action="click->flip#toggle keydown->flip#toggleKey"
             role="button" tabindex="0"
             aria-label="<%= t('cards.flip_aria') %>">
          <div class="flip-card-inner">
            <div class="flip-card-front bg-body border">
              <% if card.source_language %>
                <span class="badge bg-secondary mb-2"><%= card.source_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.front_text %></span>
            </div>
            <div class="flip-card-back bg-primary text-white">
              <% if card.target_language %>
                <span class="badge bg-light text-dark mb-2"><%= card.target_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.back_text %></span>
            </div>
          </div>
        </div>
        <div class="d-flex justify-content-center gap-2 mt-2">
          <%= link_to t("common.view"), collection_card_path(@collection, card), class: "btn btn-outline-primary btn-sm" %>
          <% if policy(card).destroy? %>
            <%= button_to t("common.delete"), collection_card_path(@collection, card), method: :delete,
                          class: "btn btn-outline-danger btn-sm",
                          form: { data: { turbo_confirm: t("common.confirm_delete_card"), turbo_preserve_scroll: true } } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">
    <%= t("cards.empty_in_collection") %>
    <% if current_user.nil? || current_user.native_language.nil? || current_user.preferred_language.nil? %>
      <%= t("cards.set_both_html", link: link_to(t("cards.your_profile"), edit_user_registration_path)).html_safe %>
    <% end %>
  </p>
<% end %>
