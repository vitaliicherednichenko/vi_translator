<% content_for :title, "Cards" %>

<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><%= "#{@collection.name} Cards" %></h1>
  <% if policy(Card).create? %>
    <%= link_to "New card", new_collection_card_path(@collection), class: "btn btn-primary" %>
  <% end %>
</div>

<% if @cards.any? %>
  <div id="cards" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <% @cards.each do |card| %>
      <div class="col">
        <div id="<%= dom_id card %>"
             class="flip-card"
             data-controller="flip"
             data-action="click->flip#toggle keydown->flip#toggleKey"
             role="button" tabindex="0"
             aria-label="Flip card to see the translation">
          <div class="flip-card-inner">
            <div class="flip-card-front bg-body border">
              <% if card.source_language %>
                <span class="badge bg-secondary mb-2"><%= card.source_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.front_text %></span>
            </div>
            <div class="flip-card-back bg-primary text-white">
              <% if card.target_language %>
                <span class="badge bg-light text-dark mb-2"><%= card.target_language.code.upcase %></span>
              <% end %>
              <span class="fs-4 fw-semibold"><%= card.back_text %></span>
            </div>
          </div>
        </div>
        <div class="d-flex justify-content-center gap-2 mt-2">
          <%= link_to "View", collection_card_path(@collection, card), class: "btn btn-outline-primary btn-sm" %>
          <% if policy(card).destroy? %>
            <%= button_to "Delete", collection_card_path(@collection, card), method: :delete,
                          class: "btn btn-outline-danger btn-sm",
                          form: { data: { turbo_confirm: "Delete this card?" } } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">
    No cards in this collection match your native and preferred languages.
    <% if current_user.nil? || current_user.native_language.nil? || current_user.preferred_language.nil? %>
      Set both in <%= link_to "your profile", edit_user_registration_path %> to see matching cards.
    <% end %>
  </p>
<% end %>
