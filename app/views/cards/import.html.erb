<% content_for :title, t("import.title") %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <h1 class="mb-4"><%= t("import.title") %> · <%= @collection.name %></h1>

    <div class="card shadow-sm">
      <div class="card-body">
        <p class="text-muted small">
          <%= t("import.into_collection_html").html_safe %>
        </p>

        <%= form_with url: import_collection_cards_path(@collection), method: :post do |f| %>
          <div class="mb-3">
            <%= f.label :file, t("import.file_label"), class: "form-label" %>
            <%= f.file_field :file, accept: ".csv,text/csv", class: "form-control", required: true %>
          </div>
          <div class="d-grid">
            <%= f.submit t("import.submit"), class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-3">
      <%= link_to t("cards.back_to_cards"), collection_cards_path(@collection), class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
