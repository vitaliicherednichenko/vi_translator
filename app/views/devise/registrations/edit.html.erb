<% content_for :title, t("devise_ui.edit_profile") %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <h2 class="mb-4 text-center"><%= t("devise_ui.edit_profile") %></h2>

    <div class="card shadow-sm">
      <div class="card-body">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <%= f.label :native_language_id, t("devise_ui.native_language"), class: "form-label" %>
              <%= f.collection_select :native_language_id, Language.all, :id, :name,
                                      { prompt: t("devise_ui.select_generic") },
                                      { class: "form-select" } %>
            </div>
            <div class="col-md-6">
              <%= f.label :preferred_language_id, t("devise_ui.learning_language"), class: "form-label" %>
              <%= f.collection_select :preferred_language_id, Language.all, :id, :name,
                                      { prompt: t("devise_ui.select_generic") },
                                      { class: "form-select" } %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <i class="text-muted"><%= t("devise_ui.leave_blank") %></i>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :current_password, class: "form-label" %>
            <i class="text-muted"><%= t("devise_ui.need_current_password") %></i>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
          </div>

          <div class="d-grid">
            <%= f.submit t("devise_ui.update"), class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm border-danger mt-3">
      <div class="card-body">
        <h3 class="h6 text-danger"><%= t("devise_ui.cancel_account") %></h3>
        <p class="text-muted small mb-3"><%= t("devise_ui.cancel_account_unhappy") %></p>
        <%= button_to t("devise_ui.cancel_account"), registration_path(resource_name),
                      data: { confirm: t("common.confirm_generic"), turbo_confirm: t("common.confirm_generic") },
                      method: :delete, class: "btn btn-outline-danger btn-sm" %>
      </div>
    </div>

    <div class="mt-3 text-center">
      <%= link_to t("devise_ui.back"), :back, class: "btn btn-link" %>
    </div>
  </div>
</div>
