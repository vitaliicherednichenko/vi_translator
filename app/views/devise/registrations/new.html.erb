<% content_for :title, t("devise_ui.sign_up") %>

<h2><%= t("devise_ui.sign_up") %></h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", autofocus: true %>
  </div>

  <div class="mb-3">
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= f.label :native_language_id, t("devise_ui.native_language"), class: "form-label" %>
      <%= f.collection_select :native_language_id, Language.all, :id, :name,
                              { prompt: t("devise_ui.select_native") },
                              { class: "form-select" } %>
    </div>
    <div class="col-md-6">
      <%= f.label :preferred_language_id, t("devise_ui.language_to_learn"), class: "form-label" %>
      <%= f.collection_select :preferred_language_id, Language.all, :id, :name,
                              { prompt: t("devise_ui.select_to_learn") },
                              { class: "form-select" } %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
    <% if @minimum_password_length %>
      <div class="form-text"><%= t("devise_ui.min_characters", count: @minimum_password_length) %></div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :password_confirmation, class: "form-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
  </div>

  <div class="d-grid">
    <%= f.submit t("devise_ui.sign_up"), class: "btn btn-primary" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
